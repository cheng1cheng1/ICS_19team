    auto x_contiguous = x.contiguous();
    auto output = torch::empty_like(x_contiguous);

    int ndim = x_contiguous.dim();

    if (dim < 0) {
        dim += ndim;
    }

    int outer_size = 1;
    int dim_size = x_contiguous.size(dim);
    int inner_size = 1;

    for (int i = 0; i < dim; ++i) {
        outer_size *= x_contiguous.size(i);
    }

    for (int i = dim + 1; i < ndim; ++i) {
        inner_size *= x_contiguous.size(i);
    }

    int total_lines = outer_size * inner_size;

    int task_num = total_lines;
    if (task_num > 16) {
        task_num = 16;
    }

    cnrtDim3_t k_dim;
    k_dim.x = task_num;
    k_dim.y = 1;
    k_dim.z = 1;

    cnrtFunctionType_t k_type = cnrtFuncTypeBlock;

    cnrtQueue_t queue;
    cnrtQueueCreate(&queue);

    cumsum_kernel<<<k_dim, k_type, queue>>>(
        reinterpret_cast<const half *>(x_contiguous.data_ptr()),
        reinterpret_cast<half *>(output.data_ptr()),
        outer_size,
        dim_size,
        inner_size,
        total_lines
    );

    cnrtQueueSync(queue);
    cnrtQueueDestroy(queue);

    return output;
}
